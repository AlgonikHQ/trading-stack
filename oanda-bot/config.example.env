# OANDA Bot — Example Configuration
# Copy to .env and populate with real values
# NEVER commit a populated .env file to version control

# ─── OANDA API ────────────────────────────────────────────────────────────────

# Live or practice API endpoint
# Live:     https://api-fxtrade.oanda.com
# Practice: https://api-fxpractice.oanda.com
OANDA_API_URL=https://api-fxtrade.oanda.com

# API key — generate from OANDA Hub (My Account > API Access)
OANDA_API_KEY=your_api_key_here

# Account ID — format: 001-004-XXXXXXXX-XXX
OANDA_ACCOUNT_ID=001-004-XXXXXXXX-XXX

# ─── CAPITAL & RISK ───────────────────────────────────────────────────────────

# Starting capital in GBP — used as the base for all risk calculations
# Risk is always calculated against this value, not running balance
LIVE_STARTING_CAPITAL=250

# Risk per trade as a decimal fraction of starting capital
# e.g. 0.02 = 2% risk per trade
RISK_PCT=0.02

# Maximum number of concurrent open trades
MAX_OPEN_TRADES=4

# Daily loss limit as a decimal fraction of opening balance
# e.g. 0.03 = halt trading after -3% day
DAILY_LOSS_LIMIT_PCT=0.03

# ─── TELEGRAM ─────────────────────────────────────────────────────────────────

# Bot token from @BotFather
TELEGRAM_BOT_TOKEN=your_bot_token_here

# Chat ID for your public alerts channel (negative number for channels)
TELEGRAM_CHAT_ID=-100XXXXXXXXXX

# ─── ENVIRONMENT ──────────────────────────────────────────────────────────────

# LIVE or DEMO — controls which API endpoint and account is used
# Always verify this before starting the service
ENV=LIVE

# Bot version — shown in Telegram heartbeats and patch notes
BOT_VERSION=v2.2

# ─── SESSION FILTERS ──────────────────────────────────────────────────────────

# London open blackout (UTC) — no new entries during this window
LONDON_OPEN_BLACKOUT_START=08:00
LONDON_OPEN_BLACKOUT_END=08:15

# Friday session cutoff — no new entries after this time UTC
FRIDAY_NO_ENTRY_AFTER=18:00

# Friday force-close all positions at this time UTC
FRIDAY_CLOSE_ALL=20:00

# ─── INSTRUMENT-SPECIFIC SL FLOORS (pips) ────────────────────────────────────

# Minimum SL distance enforced per pair regardless of calculated SL
SL_FLOOR_GBPJPY=15
SL_FLOOR_USDJPY=10
SL_FLOOR_GBPUSD=10
SL_FLOOR_DEFAULT=8
