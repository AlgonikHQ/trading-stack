# OANDA Bot — Example Configuration
# Copy to .env and populate with real values
# NEVER commit a populated .env file to version control

# ─── OANDA API ────────────────────────────────────────────────────────────────
# Live:     https://api-fxtrade.oanda.com
# Practice: https://api-fxpractice.oanda.com
OANDA_API_URL=https://api-fxtrade.oanda.com
OANDA_API_KEY=your_api_key_here
OANDA_ACCOUNT_ID=001-004-XXXXXXXX-XXX

# ─── CAPITAL & RISK ───────────────────────────────────────────────────────────
LIVE_STARTING_CAPITAL=250
RISK_PCT=0.02
MAX_OPEN_TRADES=3
DAILY_LOSS_LIMIT_PCT=0.03

# ─── TELEGRAM ─────────────────────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=your_bot_token_here
TELEGRAM_CHAT_ID=-100XXXXXXXXXX
PUBLIC_CHANNEL_ID=-100XXXXXXXXXX

# ─── ENVIRONMENT ──────────────────────────────────────────────────────────────
ENV=LIVE
BOT_VERSION=v2.6

# ─── VIX FILTER ───────────────────────────────────────────────────────────────
# Block new entries when VIX exceeds this level (NY session only)
VIX_WARN_THRESHOLD=25
# Emergency close all positions when VIX exceeds this level
VIX_CLOSE_THRESHOLD=35
# Cache VIX value for this many seconds before re-fetching
VIX_CACHE_SECONDS=900

# ─── SESSION FILTERS ──────────────────────────────────────────────────────────
LONDON_OPEN_BLACKOUT_START=08:00
LONDON_OPEN_BLACKOUT_END=08:15
FRIDAY_NO_ENTRY_AFTER=18:00
FRIDAY_CLOSE_ALL=20:00

# ─── INSTRUMENT SL FLOORS (pips) ─────────────────────────────────────────────
SL_FLOOR_GBPJPY=15
SL_FLOOR_USDJPY=10
SL_FLOOR_GBPUSD=10
SL_FLOOR_DEFAULT=8
